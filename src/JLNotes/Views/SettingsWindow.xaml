<Window x:Class="JLNotes.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="360" Height="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Border Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontFamily="Segoe UI" Margin="0,0,0,16" />

            <!-- Theme -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Theme" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                <ComboBox Grid.Column="1" x:Name="ThemeCombo"
                          Width="100"
                          Style="{StaticResource DarkComboBox}"
                          SelectionChanged="ThemeCombo_SelectionChanged">
                    <ComboBoxItem Content="Dark" />
                    <ComboBoxItem Content="Light" />
                </ComboBox>
            </Grid>

            <!-- Subtitle Display -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Show under title" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                <ComboBox Grid.Column="1" x:Name="SubtitleCombo"
                          Width="100"
                          Style="{StaticResource DarkComboBox}"
                          SelectionChanged="SubtitleCombo_SelectionChanged">
                    <ComboBoxItem Content="Project" Tag="project" />
                    <ComboBoxItem Content="Repo" Tag="repo" />
                    <ComboBoxItem Content="Tags" Tag="tags" />
                </ComboBox>
            </Grid>

            <!-- Close behavior -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Close button" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI" />
                <ComboBox Grid.Column="1" x:Name="CloseBehaviorCombo"
                          Width="130"
                          Style="{StaticResource DarkComboBox}"
                          SelectionChanged="CloseBehaviorCombo_SelectionChanged">
                    <ComboBoxItem Content="Minimize to tray" Tag="tray" />
                    <ComboBoxItem Content="Quit app" Tag="quit" />
                </ComboBox>
            </Grid>

            <!-- Confirm Delete -->
            <CheckBox x:Name="ConfirmDeleteCheck"
                      Content="Confirm before deleting notes"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      FontFamily="Segoe UI"
                      Margin="0,0,0,16"
                      Checked="ConfirmDelete_Changed"
                      Unchecked="ConfirmDelete_Changed" />

            <!-- Projects -->
            <TextBlock Text="Projects" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontFamily="Segoe UI" Margin="0,0,0,8" />

            <ListBox x:Name="ProjectList"
                     Height="100"
                     Background="{DynamicResource BgSecondaryBrush}"
                     BorderBrush="{DynamicResource BorderSubtleBrush}"
                     BorderThickness="1"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     FontFamily="Segoe UI" FontSize="12"
                     Margin="0,0,0,8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" FontSize="12" />
                            <TextBlock Text="{Binding Repo}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="10" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="+ Add"
                        Style="{StaticResource SubtleButton}"
                        Foreground="{DynamicResource AccentBlueBrush}"
                        Click="AddProject_Click" />
                <Button Content="Remove"
                        Style="{StaticResource SubtleButton}"
                        Click="RemoveProject_Click" />
                <Button Content="Browse Repo"
                        Style="{StaticResource SubtleButton}"
                        Click="BrowseProjectRepo_Click" />
            </StackPanel>

            <!-- Close -->
            <Button Content="Close" HorizontalAlignment="Right"
                    Style="{StaticResource SubtleButton}"
                    Foreground="{DynamicResource AccentBlueBrush}"
                    Click="Close_Click" />
        </StackPanel>
    </Border>
</Window>
