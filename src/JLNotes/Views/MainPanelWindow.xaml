<Window x:Class="JLNotes.Views.MainPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:JLNotes.ViewModels"
        Title="JL Notes"
        Icon="pack://application:,,,/tray.ico"
        Width="380" Height="550"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"

        ShowInTaskbar="True"
        ResizeMode="CanResize"
        MinWidth="250" MinHeight="300"
        PreviewKeyDown="Window_PreviewKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="12,10" MouseLeftButtonDown="Header_MouseLeftButtonDown" MouseMove="Header_MouseMove"
                    Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="8,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding SelectedProject}"
                              Style="{StaticResource DarkComboBox}"
                              Width="180" HorizontalAlignment="Left" />

                    <Button Grid.Column="1" Content="+" Style="{StaticResource SubtleButton}"
                            FontSize="18" Margin="8,0"
                            Click="AddNote_Click" />

                    <Button Grid.Column="2" Content="&#x2699;" Style="{StaticResource SubtleButton}"
                            FontSize="14" Margin="0,0,4,0"
                            Click="Settings_Click"
                            ToolTip="Settings" />

                    <Button Grid.Column="3" Content="&#x2500;" Style="{StaticResource SubtleButton}"
                            FontSize="11" Margin="0,0,4,0"
                            Click="Minimize_Click"
                            ToolTip="Minimize" />

                    <Button Grid.Column="4" x:Name="MaximizeButton" Content="&#x1F5D6;" Style="{StaticResource SubtleButton}"
                            FontSize="11" Margin="0,0,4,0"
                            Click="Maximize_Click"
                            ToolTip="Maximize" />

                    <Button Grid.Column="5" Content="x" Style="{StaticResource SubtleButton}"
                            FontSize="14"
                            Click="Close_Click"
                            ToolTip="Close to tray" />
                </Grid>
            </Border>

            <!-- Search Bar + Group Toggle -->
            <Border Grid.Row="1" Padding="8,6"
                    Background="{DynamicResource BgPrimaryBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource BgSecondaryBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderSubtleBrush}"
                             FontFamily="Segoe UI" FontSize="14"
                             Padding="8,5"
                             Tag="Search notes..."
                             Style="{StaticResource SearchBox}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ToggleButton IsChecked="{Binding ShowCompleted}"
                                      ToolTip="Show completed"
                                      Style="{StaticResource SubtleToggleButton}"
                                      Content="&#x2713;"
                                      FontSize="14"
                                      Margin="6,0,0,0"
                                      Padding="4,2" />
                        <ToggleButton IsChecked="{Binding GroupByProject}"
                                      ToolTip="Group by project"
                                      Style="{StaticResource SubtleToggleButton}"
                                      Content="&#x25A6;"
                                      FontSize="14"
                                      Margin="4,0,0,0"
                                      Padding="4,2" />
                        <ToggleButton IsChecked="{Binding IsSelectMode}"
                                      ToolTip="Select notes"
                                      Style="{StaticResource SubtleToggleButton}"
                                      Content="&#x2610;"
                                      FontSize="14"
                                      Margin="4,0,0,0"
                                      Padding="4,2" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Note List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource DarkScrollViewer}"
                          Padding="8"
                          PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <Grid>
                    <!-- Priority View (default) -->
                    <StackPanel Visibility="{Binding GroupByProject, Converter={StaticResource InverseBoolToVisibility}}">
                        <!-- High Priority -->
                        <TextBlock Text="HIGH" Style="{StaticResource SecondaryText}"
                                   Margin="4,8,0,4"
                                   Visibility="{Binding HighPriority.Count, Converter={StaticResource CountToVisibility}}" />
                        <ItemsControl ItemsSource="{Binding HighPriority}"
                                      ItemTemplate="{StaticResource NoteItemTemplate}" />

                        <!-- Medium Priority -->
                        <TextBlock Text="MEDIUM" Style="{StaticResource SecondaryText}"
                                   Margin="4,12,0,4"
                                   Visibility="{Binding MediumPriority.Count, Converter={StaticResource CountToVisibility}}" />
                        <ItemsControl ItemsSource="{Binding MediumPriority}"
                                      ItemTemplate="{StaticResource NoteItemTemplate}" />

                        <!-- Low Priority -->
                        <TextBlock Text="LOW" Style="{StaticResource SecondaryText}"
                                   Margin="4,12,0,4"
                                   Visibility="{Binding LowPriority.Count, Converter={StaticResource CountToVisibility}}" />
                        <ItemsControl ItemsSource="{Binding LowPriority}"
                                      ItemTemplate="{StaticResource NoteItemTemplate}" />
                    </StackPanel>

                    <!-- Project Group View -->
                    <ItemsControl ItemsSource="{Binding ProjectGroups}"
                                  Visibility="{Binding GroupByProject, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,0">
                                    <!-- Project header -->
                                    <Border Margin="0,4,0,6" Padding="0,0,0,4"
                                            BorderThickness="0,0,0,2"
                                            BorderBrush="{Binding ColorBrush}">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{Binding ColorBrush}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI"
                                                   Margin="4,0,0,0" />
                                    </Border>
                                    <!-- Notes in this project -->
                                    <ItemsControl ItemsSource="{Binding Notes}"
                                                  ItemTemplate="{StaticResource NoteItemTemplate}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- Selection Action Bar -->
            <Border Grid.Row="3"
                    Padding="12,8"
                    Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Visibility="{Binding IsSelectMode, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource SecondaryText}"
                               VerticalAlignment="Center">
                        <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                        <Run Text=" selected" />
                    </TextBlock>
                    <Button Grid.Column="1"
                            Content="Export to Word"
                            Style="{StaticResource SubtleButton}"
                            Foreground="{DynamicResource AccentBlueBrush}"
                            Command="{Binding ExportSelectedCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
