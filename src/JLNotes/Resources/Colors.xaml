<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="BgPrimary">#1a1a2e</Color>
    <Color x:Key="BgSecondary">#16213e</Color>
    <Color x:Key="BgTertiary">#0f3460</Color>
    <Color x:Key="BgHover">#1f2b47</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#e0e0e0</Color>
    <Color x:Key="TextSecondary">#8899aa</Color>
    <Color x:Key="TextMuted">#556677</Color>

    <!-- Accents -->
    <Color x:Key="AccentBlue">#4a9eff</Color>
    <Color x:Key="AccentRed">#ef4444</Color>
    <Color x:Key="AccentAmber">#f59e0b</Color>
    <Color x:Key="AccentMutedBlue">#649ecf</Color>
    <Color x:Key="AccentGreen">#34d399</Color>

    <!-- Border -->
    <Color x:Key="BorderSubtle">#2a2a4a</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}" />
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
</ResourceDictionary>
