<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="BgPrimary">#f5f5f5</Color>
    <Color x:Key="BgSecondary">#ffffff</Color>
    <Color x:Key="BgTertiary">#e8edf2</Color>
    <Color x:Key="BgHover">#eaeff4</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#1a1a2e</Color>
    <Color x:Key="TextSecondary">#5a6a7a</Color>
    <Color x:Key="TextMuted">#8899aa</Color>

    <!-- Accents -->
    <Color x:Key="AccentBlue">#2563eb</Color>
    <Color x:Key="AccentRed">#dc2626</Color>
    <Color x:Key="AccentAmber">#d97706</Color>
    <Color x:Key="AccentMutedBlue">#3b82f6</Color>
    <Color x:Key="AccentGreen">#059669</Color>

    <!-- Border -->
    <Color x:Key="BorderSubtle">#d1d5db</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}" />
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
</ResourceDictionary>
